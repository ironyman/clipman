<Window
    x:Class="Clipman.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Clipman.Converters"
    xmlns:models="using:Clipman.Models"
    Title="Clipman">
    <Grid x:Name="Root" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:ClipKindToIconGlyphConverter x:Key="KindIconConverter" />
            <converters:PinnedGlyphConverter x:Key="PinnedGlyphConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

            <Style x:Key="MetricTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>

            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="TitleBarIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="46" />
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="46" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="DragRegion" Height="32" Padding="16,0,0,0" ColumnSpacing="12" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="TitleLeftPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8C8;" FontSize="18" />
                <TextBlock Text="Clipman" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="TitleActionsPanel" Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button
                    x:Name="RightPanelToggleButton"
                    Style="{StaticResource TitleBarIconButtonStyle}"
                    ToolTipService.ToolTip="Toggle details panel"
                    Click="RightPanelToggleButton_Click">
                    <FontIcon x:Name="RightPanelToggleIcon" Glyph="&#xE8A1;" />
                </Button>
                <Button
                    x:Name="SettingsButton"
                    Style="{StaticResource TitleBarIconButtonStyle}"
                    ToolTipService.ToolTip="Settings"
                    Click="SettingsButton_Click">
                    <FontIcon Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="MainContentGrid" Grid.Row="1" Padding="16,8,16,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HistoryColumn" Width="420" MinWidth="320" />
                <ColumnDefinition x:Name="DetailsColumn" Width="*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="HistoryPaneHost" Grid.Column="0" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox
                        x:Name="SearchBox"
                        QueryIcon="Find"
                        PlaceholderText="Search clipboard history"
                        KeyDown="SearchBox_KeyDown"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        TextChanged="SearchBox_TextChanged" />

                    <Button Grid.Column="1" ToolTipService.ToolTip="Advanced search" Click="AdvancedSearchButton_Click">
                        <FontIcon Glyph="&#xE71C;" />
                    </Button>
                </Grid>

                <ItemsControl x:Name="SearchBadgesItemsControl" Grid.Row="1" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,8,8"
                                Padding="10,4"
                                CornerRadius="12"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Label}" />
                                    <Button
                                        Padding="0"
                                        MinWidth="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Tag="{Binding Token}"
                                        Click="RemoveSearchBadgeButton_Click">
                                        <FontIcon Glyph="&#xE711;" FontSize="11" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="All" Tag="" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="Text" Tag="Text" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="Code" Tag="Code" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="URL" Tag="Url" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="Image" Tag="Image" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="Video" Tag="Video" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="File" Tag="File" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                        <Button Content="HTML" Tag="Html" Click="FilterButton_Click" Style="{StaticResource FilterButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>

                <ListView
                    x:Name="HistoryListView"
                    Grid.Row="3"
                    ItemsSource="{Binding VisibleClips}"
                    SelectedItem="{Binding SelectedClip, Mode=TwoWay}"
                    SelectionMode="Single"
                    SelectionChanged="HistoryListView_SelectionChanged"
                    KeyDown="HistoryListView_KeyDown"
                    ContainerContentChanging="HistoryListView_ContainerContentChanging"
                    Loaded="HistoryListView_Loaded">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ClipboardClip">
                            <Grid Padding="12" ColumnSpacing="12" MinHeight="92">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="HistoryKindIconHost"
                                    Width="40"
                                    Height="40"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <FontIcon
                                        x:Name="HistoryKindIcon"
                                        Glyph="{Binding Kind, Converter={StaticResource KindIconConverter}}"
                                        FontSize="18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>
                                <Border
                                    x:Name="HistoryImageHost"
                                    Width="40"
                                    Height="40"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    Visibility="Collapsed">
                                    <Image
                                        x:Name="HistoryImage"
                                        Stretch="UniformToFill"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch" />
                                </Border>
                                <Border
                                    x:Name="HistoryAppIconHost"
                                    Width="40"
                                    Height="40"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    Visibility="Collapsed">
                                    <Image
                                        x:Name="HistoryAppIcon"
                                        Stretch="Uniform"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch" />
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{Binding Preview}"
                                        MaxLines="2"
                                        TextWrapping="Wrap"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding Metadata}" Style="{StaticResource MetricTextStyle}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <FontIcon
                                    Grid.Column="2"
                                    Glyph="{Binding IsPinned, Converter={StaticResource PinnedGlyphConverter}}"
                                    FontSize="13"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    VerticalAlignment="Top" />
                                <TextBlock
                                    x:Name="SlotHintTextBlock"
                                    Grid.Column="2"
                                    Margin="0,18,0,0"
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    HorizontalAlignment="Right"
                                    Visibility="Collapsed" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </Grid>

            <Grid Grid.Column="1" x:Name="RightPanelHost" RowSpacing="12" Opacity="1">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTranslateTransform" X="0" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding FilterLabel}" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource MetricTextStyle}">
                            <Run Text="{Binding SavedCount}" />
                            <Run Text=" saved clips - " />
                            <Run Text="{Binding PinnedCount}" />
                            <Run Text=" pinned" />
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Padding="20"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding SelectedClip.Title}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedClip.Metadata}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel
                                Spacing="2"
                                Visibility="{Binding SelectedClip.SourceUrl, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="URL" Style="{StaticResource MetricTextStyle}" />
                                <TextBlock
                                    Text="{Binding SelectedClip.SourceUrl}"
                                    TextWrapping="Wrap"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel x:Name="TagBadgesSection" Spacing="4" Visibility="Collapsed">
                                <TextBlock Text="Tags" Style="{StaticResource MetricTextStyle}" />
                                <ItemsControl x:Name="TagBadgesItemsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,6,6"
                                                Padding="10,4"
                                                CornerRadius="12"
                                                Background="{ThemeResource AccentFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <ScrollViewer x:Name="PreviewScrollViewer">
                                <TextBlock
                                    x:Name="SelectedPreviewTextBlock"
                                    Text="{Binding SelectedClip.DisplayContent}"
                                    FontSize="15"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True" />
                            </ScrollViewer>
                            <ScrollViewer x:Name="SelectedPreviewImageScrollViewer" Visibility="Collapsed">
                                <Border
                                    Padding="8"
                                    CornerRadius="8"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Image
                                        x:Name="SelectedPreviewImage"
                                        Stretch="Uniform"
                                        MaxHeight="420"
                                        HorizontalAlignment="Stretch" />
                                </Border>
                            </ScrollViewer>
                            <ScrollViewer x:Name="SelectedPreviewFileScrollViewer" Visibility="Collapsed">
                                <TextBlock
                                    x:Name="SelectedPreviewFileTextBlock"
                                    FontSize="14"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True" />
                            </ScrollViewer>
                            <TextBox
                                x:Name="SelectedPreviewTextBox"
                                Visibility="Collapsed"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                MinHeight="240" />
                        </Grid>

                        <StackPanel
                            x:Name="EditButtonsPanel"
                            Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <Button Click="SaveEdit_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" />
                                    <TextBlock Text="Save" />
                                </StackPanel>
                            </Button>
                            <Button Click="CancelEdit_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" />
                                    <TextBlock Text="Cancel" />
                                </StackPanel>
                            </Button>
                            <Button Click="ToggleRecord_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" />
                                    <TextBlock x:Name="RecordButtonText" Text="Record" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>

                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button HorizontalAlignment="Stretch" Click="CopyClip_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C8;" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" HorizontalAlignment="Stretch" Click="PasteClip_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77F;" />
                            <TextBlock Text="Paste" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" HorizontalAlignment="Stretch" Click="ShowClipInfo_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" />
                            <TextBlock Text="Details" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" HorizontalAlignment="Stretch" Click="EditClip_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE70F;" />
                            <TextBlock Text="Edit" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4" HorizontalAlignment="Stretch" Click="TogglePin_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE718;" />
                            <TextBlock Text="Pin" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="5" HorizontalAlignment="Stretch" Click="DeleteClip_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" />
                            <TextBlock Text="Delete" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="6" HorizontalAlignment="Stretch" Click="AddTags_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8EC;" />
                            <TextBlock Text="Add Tags" />
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>

        <ContentDialog
            x:Name="AddTagsDialog"
            Title="Add tags"
            PrimaryButtonText="Save"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="AddTagsDialog_PrimaryButtonClick">
            <StackPanel Spacing="8">
                <TextBlock Text="Add tags separated by commas or new lines." TextWrapping="Wrap" />
                <TextBox
                    x:Name="TagInputTextBox"
                    PlaceholderText="work, docs, urgent"
                    AcceptsReturn="True"
                    MinWidth="320"
                    MinHeight="120"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Window>
