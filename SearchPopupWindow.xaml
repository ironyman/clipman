<Window
    x:Class="Clipman.SearchPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Clipman.Converters"
    xmlns:models="using:Clipman.Models"
    Title="Clipman Search">

    <Grid x:Name="Root" Padding="18" RowSpacing="12" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:ClipKindToIconGlyphConverter x:Key="KindIconConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <AutoSuggestBox
            x:Name="SearchBox"
            QueryIcon="Find"
            PlaceholderText="Search clipboard history"
            Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <ListView
            Grid.Row="1"
            ItemsSource="{Binding VisibleClips}"
            SelectedItem="{Binding SelectedClip, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ClipboardClip">
                    <Grid Padding="10" ColumnSpacing="10" MinHeight="72">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Glyph="{Binding Kind, Converter={StaticResource KindIconConverter}}"
                            FontSize="17"
                            VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Preview}" MaxLines="2" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding Metadata}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            Command="{Binding LoadMoreCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE710;" />
                <TextBlock Text="More" />
            </StackPanel>
        </Button>
    </Grid>
</Window>
